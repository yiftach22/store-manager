generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  WORKER
  ORDERS
}

model User {
  id              Int             @id @default(autoincrement())
  name            String
  email           String          @unique
  passwordHash    String
  role            Role            @default(WORKER)
  createdAt       DateTime        @default(now())
  jobRoles        UserJobRole[]
  completedTasks  TaskInstance[]
  completedOrders OrderInstance[]
}

// Job role / position (e.g. קופאי, מלצר) — manager-created, distinct from auth Role enum
model JobRole {
  id            Int            @id @default(autoincrement())
  name          String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  templates     TaskTemplate[]
  instances     TaskInstance[]
  users         UserJobRole[]
  allowedEmails AllowedEmail[]
}

// Many-to-many: user ↔ job role (enforced as one per user at app level for now)
model UserJobRole {
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  role       JobRole  @relation(fields: [roleId], references: [id])
  roleId     Int
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
}

model TaskTemplate {
  id        Int            @id @default(autoincrement())
  title     String
  frequency String         // 'daily' | 'weekly'
  isActive  Boolean        @default(true)
  role      JobRole        @relation(fields: [roleId], references: [id])
  roleId    Int
  instances TaskInstance[]
}

// Shared per role — one instance per template per day/week, checked off by any worker in the role
model TaskInstance {
  id              Int           @id @default(autoincrement())
  title           String
  frequency       String        // 'daily' | 'weekly'
  status          Boolean       @default(false)
  date            DateTime      // daily: specific date; weekly: week's Sunday
  role            JobRole       @relation(fields: [roleId], references: [id])
  roleId          Int
  template        TaskTemplate? @relation(fields: [templateId], references: [id])
  templateId      Int?
  completedAt     DateTime?
  completedBy     User?         @relation(fields: [completedById], references: [id])
  completedById   Int?
}

model AllowedEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  role      Role     @default(WORKER)
  jobRole   JobRole? @relation(fields: [jobRoleId], references: [id])
  jobRoleId Int?
  createdAt DateTime @default(now())
}

model OrderList {
  id        Int             @id @default(autoincrement())
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  templates OrderTemplate[]
  instances OrderInstance[]
}

model OrderTemplate {
  id        Int             @id @default(autoincrement())
  title     String
  dayOfWeek Int?            // 0=Sun, 1=Mon … 6=Sat; null=floating (belongs to a list)
  category  String          // 'daily' | 'floating'
  isActive  Boolean         @default(true)
  list      OrderList?      @relation(fields: [listId], references: [id])
  listId    Int?
  instances OrderInstance[]
}

model OrderInstance {
  id            Int            @id @default(autoincrement())
  title         String
  originalDate  DateTime
  currentDate   DateTime
  status        Boolean        @default(false)
  category      String
  isOverdue     Boolean        @default(false)
  completedAt   DateTime?
  completedBy   User?          @relation(fields: [completedById], references: [id])
  completedById Int?
  createdAt     DateTime       @default(now())
  template      OrderTemplate? @relation(fields: [templateId], references: [id])
  templateId    Int?
  list          OrderList?     @relation(fields: [listId], references: [id])
  listId        Int?
}
